    .to(letters, { y: 0, opacity: 1, stagger: 0.02 });\\\\n          };\\\\n          const stopHover = () => {\\\\n            if (hoverTl) {\\\\n              hoverTl.kill();\\\\n              hoverTl = null;\\\\n              gsap.set(letters, { y: 0, opacity: 1 });\\\\n            }\\\\n          };\\\\n          title.addEventListener(\\\\'mouseenter\\\\', startHover);\\\\n          title.addEventListener(\\\\'mouseleave\\\\', stopHover);\\\\n          title.addEventListener(\\\\'focus\\\\', startHover);\\\\n          title.addEventListener(\\\\'blur\\\\', stopHover);\",\"originAcceptText\":\"          let hoverTl = null;\\n          const startHover = () => {\\n            if (hoverTl) return;\\n            hoverTl = gsap.timeline({ repeat: -1, defaults: { duration: 0.8, ease: 'power2.inOut' } });\\n            hoverTl\\n              .to(letters, { y: -4, opacity: 0.95, stagger: 0.02 })\\n              .to(letters, { y: 0, opacity: 1, stagger: 0.02 });\\n          };\\n          const stopHover = () => {\\n            if (hoverTl) {\\n              hoverTl.kill();\\n              hoverTl = null;\\n              gsap.set(letters, { y: 0, opacity: 1 });\\n            }\\n          };\\n          title.addEventListener('mouseenter', startHover);\\n          title.addEventListener('mouseleave', stopHover);\\n          title.addEventListener('focus', startHover);\\n          title.addEventListener('blur', stopHover);\",\"originTextLength\":801,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019215718},{\"originRange\":{\"start\":{\"line\":204,\"character\":0},\"end\":{\"line\":204,\"character\":35}},\"modifyRange\":{\"start\":{\"line\":204,\"character\":0},\"end\":{\"line\":204,\"character\":35}},\"action\":\"None\",\"isLine\":false,\"originText\":\"  const toggleTheme = async () => {\",\"originAcceptText\":\"  const toggleTheme = async () => {\",\"originTextLength\":35,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":17670