hero h1, .section-title, .card\\\\').forEach((el) => {\",\"originAcceptText\":\"        // Only check main sections to save performance\\n        document.querySelectorAll('.hero h1, .section-title, .card').forEach((el) => {\",\"originTextLength\":142,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090152},{\"originRange\":{\"start\":{\"line\":171,\"character\":0},\"end\":{\"line\":172,\"character\":82}},\"modifyRange\":{\"start\":{\"line\":171,\"character\":0},\"end\":{\"line\":172,\"character\":82}},\"action\":\"None\",\"isLine\":false,\"originText\":\"          // Normalize to roughly -1 to 1 screen space, then to world space\\\\n          // This is an approximation. A simpler way is to just keep center clear.\",\"originAcceptText\":\"          // Normalize to roughly -1 to 1 screen space, then to world space\\n          // This is an approximation. A simpler way is to just keep center clear.\",\"originTextLength\":158,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090154},{\"originRange\":{\"start\":{\"line\":174,\"character\":0},\"end\":{\"line\":182,\"character\":50}},\"modifyRange\":{\"start\":{\"line\":174,\"character\":0},\"end\":{\"line\":182,\"character\":50}},\"action\":\"None\",\"isLine\":false,\"originText\":\"        moving.forEach((mesh) => {\\\\n          // 1. Rotation\\\\n          mesh.rotation.x += mesh.userData.rotVel.x;\\\\n          mesh.rotation.y += mesh.userData.rotVel.y;\\\\n\\\\n          // 2. Move\\\\n          // We use baseVel + repulsion, but we don\\\\'t modify baseVel permanently\\\\n          const currentVel = mesh.userData.baseVel.clone();\\\\n\\\\n          // Repulsion logic\\\\n          // Project mesh position to screen space\",\"originAcceptText\":\"        moving.forEach((mesh) => {\\n          // 1. Rotation\\n          mesh.rotation.x += mesh.userData.rotVel.x;\\n          mesh.rotation.y += mesh.userData.rotVel.y;\\n\\n          // 2. Move\\n          // We use baseVel + repulsion, but we don't modify baseVel permanently\\n          const currentVel = mesh.userData.baseVel.clone();\\n\\n          // Repulsion logic\\n          // Project mesh position to screen space\",\"originTextLength\":409,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090161},{\"originRange\":{\"start\":{\"line\":181,\"character\":0},\"end\":{\"line\":182,\"character\":32}},\"modifyRange\":{\"start\":{\"line\":181,\"character\":0},\"end\":{\"line\":182,\"character\":32}},\"action\":\"None\",\"isLine\":false,\"originText\":\"\\\\n          // Check against rects\",\"originAcceptText\":\"\\n          // Check against rects\",\"originTextLength\":33,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090163},{\"originRange\":{\"start\":{\"line\":183,\"character\":0},\"end\":{\"line\":195,\"character\":83}},\"modifyRange\":{\"start\":{\"line\":183,\"character\":0},\"end\":{\"line\":195,\"character\":83}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            if (sx >= r.left - 50 && sx <= r.right + 50 && sy >= r.top - 50 && sy <= r.bottom + 50) {\\\\n              // Push away\\\\n              const centerX = r.left + r.width / 2;\\\\n              const centerY = r.top + r.height / 2;\\\\n              const dx = sx - centerX;\\\\n              const dy = sy - centerY;\\\\n              \\\\n              // Normalize and add to velocity\\\\n              const dist = Math.sqrt(dx*dx + dy*dy) || 1;\\\\n              const force = 0.05 * speed; // Repulsion strength\\\\n              \\\\n              currentVel.x += (dx / dist) * force;\\\\n              currentVel.y -= (dy / dist) * force; // Y is inverted in 3D vs screen\",\"originAcceptText\":\"            if (sx >= r.left - 50 && sx <= r.right + 50 && sy >= r.top - 50 && sy <= r.bottom + 50) {\\n              // Push away\\n              const centerX = r.left + r.width / 2;\\n              const centerY = r.top + r.height / 2;\\n              const dx = sx - centerX;\\n              const dy = sy - centerY;\\n              \\n              // Normalize and add to velocity\\n              const dist = Math.sqrt(dx*dx + dy*dy) || 1;\\n              const force = 0.05 * speed; // Repulsion strength\\n              \\n              currentVel.x += (dx / dist) * force;\\n              currentVel.y -= (dy / dist) * force; // Y is inverted in 3D vs screen\",\"originTextLength\":644,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090166},{\"originRange\":{\"start\":{\"line\":192,\"character\":0},\"end\":{\"line\":202,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":192,\"character\":0},\"end\":{\"line\":202,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"\\\\n          mesh.position.add(currentVel);\\\\n\\\\n          // 3. Bounds Wrapping\\\\n          if (mesh.position.x > 40) mesh.position.x = -40;\\\\n          if (mesh.position.x < -40) mesh.position.x = 40;\\\\n          if (mesh.position.y > 25) mesh.position.y = -25;\\\\n          if (mesh.position.y < -25) mesh.position.y = 25;\\\\n        });\\\\n\\\\n        // Rotate particles slowly\\\\n        particles.rotation.y = time * 0.02 * speed;\\\\n\",\"originAcceptText\":\"\\n          mesh.position.add(currentVel);\\n\\n          // 3. Bounds Wrapping\\n          if (mesh.position.x > 40) mesh.position.x = -40;\\n          if (mesh.position.x < -40) mesh.position.x = 40;\\n          if (mesh.position.y > 25) mesh.position.y = -25;\\n          if (mesh.position.y < -25) mesh.position.y = 25;\\n        });\\n\\n        // Rotate particles slowly\\n        particles.rotation.y = time * 0.02 * speed;\\n\",\"originTextLength\":411,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767280090169},{\"originRange\":{\"start\":{\"line\":212,\"character\":0},\"end\":{\"line\":213,\"character\":63}},\"modifyRange\":{\"start\":{\"line\":212,\"character\":0},\"end\":{\"line\":213,\"character\":