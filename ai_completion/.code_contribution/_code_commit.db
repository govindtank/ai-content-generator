            ease: 'power2.out',\\n            onComplete: () => overlay.remove(),\\n          });\\n        },\\n      }\\n    );\",\"originTextLength\":805,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019215752},{\"originRange\":{\"start\":{\"line\":296,\"character\":0},\"end\":{\"line\":299,\"character\":43}},\"modifyRange\":{\"start\":{\"line\":296,\"character\":0},\"end\":{\"line\":299,\"character\":43}},\"action\":\"None\",\"isLine\":false,\"originText\":\"          </div>\\\\n          <div className=\\\\\\\"gt-logo\\\\\\\" aria-hidden=\\\\\\\"true\\\\\\\">\\\\n            <span className=\\\\\\\"gt-g\\\\\\\">G</span>\\\\n            <span className=\\\\\\\"gt-t\\\\\\\">T</span>\",\"originAcceptText\":\"          </div>\\n          <div className=\\\"gt-logo\\\" aria-hidden=\\\"true\\\">\\n            <span className=\\\"gt-g\\\">G</span>\\n            <span className=\\\"gt-t\\\">T</span>\",\"originTextLength\":159,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019215761},{\"originRange\":{\"start\":{\"line\":118,\"character\":0},\"end\":{\"line\":119,\"character\":58}},\"modifyRange\":{\"start\":{\"line\":118,\"character\":0},\"end\":{\"line\":119,\"character\":58}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            span.className = ch === \\\\' \\\\' ? \\\\'title-space\\\\' : \\\\'title-letter\\\\';\\\\n            span.textContent = ch === \\\\' \\\\' ? \\\\'\\\\\\\\u00A0\\\\' : ch;\",\"originAcceptText\":\"            span.className = ch === ' ' ? 'title-space' : 'title-letter';\\n            span.textContent = ch === ' ' ? '\\\\u00A0' : ch;\",\"originTextLength\":132,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019562224},{\"originRange\":{\"start\":{\"line\":123,\"character\":0},\"end\":{\"line\":137,\"character\":57}},\"modifyRange\":{\"start\":{\"line\":123,\"character\":0},\"end\":{\"line\":137,\"character\":57}},\"action\":\"None\",\"isLine\":false,\"originText\":\"          const letters = title.querySelectorAll(\\\\'.title-letter, .title-space\\\\');\\\\n          const caret = document.createElement(\\\\'span\\\\');\\\\n          caret.className = \\\\'type-caret\\\\';\\\\n          title.appendChild(caret);\\\\n          gsap.set(letters, { opacity: 0 });\\\\n          let tl = gsap.timeline({ defaults: { ease: \\\\'power2.out\\\\' } });\\\\n          tl.to(letters, { opacity: 1, duration: 0.02, stagger: 0.045 });\\\\n          const restartTyping = () => {\\\\n            tl.kill();\\\\n            gsap.set(letters, { opacity: 0 });\\\\n            tl = gsap.timeline({ defaults: { ease: \\\\'power2.out\\\\' } });\\\\n            tl.to(letters, { opacity: 1, duration: 0.02, stagger: 0.045 });\\\\n          };\\\\n          title.addEventListener(\\\\'mouseenter\\\\', restartTyping);\\\\n          title.addEventListener(\\\\'focus\\\\', restartTyping);\",\"originAcceptText\":\"          const letters = title.querySelectorAll('.title-letter, .title-space');\\n          const caret = document.createElement('span');\\n          caret.className = 'type-caret';\\n          title.appendChild(caret);\\n          gsap.set(letters, { opacity: 0 });\\n          let tl = gsap.timeline({ defaults: { ease: 'power2.out' } });\\n          tl.to(letters, { opacity: 1, duration: 0.02, stagger: 0.045 });\\n          const restartTyping = () => {\\n            tl.kill();\\n            gsap.set(letters, { opacity: 0 });\\n            tl = gsap.timeline({ defaults: { ease: 'power2.out' } });\\n            tl.to(letters, { opacity: 1, duration: 0.02, stagger: 0.045 });\\n          };\\n          title.addEventListener('mouseenter', restartTyping);\\n          title.addEventListener('focus', restartTyping);\",\"originTextLength\":795,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019562230},{\"originRange\":{\"start\":{\"line\":159,\"character\":0},\"end\":{\"line\":159,\"character\":30}},\"modifyRange\":{\"start\":{\"line\":159,\"character\":0},\"end\":{\"line\":159,\"character\":30}},\"action\":\"None\",\"isLine\":false,\"originText\":\"              restartTyping();\",\"originAcceptText\":\"              restartTyping();\",\"originTextLength\":30,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019562236},{\"originRange\":{\"start\":{\"line\":166,\"character\":0},\"end\":{\"line\":166,\"character\":30}},\"modifyRange\":{\"start\":{\"line\":166,\"character\":0},\"end\":{\"line\":166,\"character\":30}},\"action\":\"None\",\"isLine\":false,\"originText\":\"              restartTyping();\",\"originAcceptText\":\"              restartTyping();\",\"originTextLength\":30,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767019562241},{\"originRange\":{\"start\":{\"line\":10,\"character\":0},\"end\":{\"line\":10,\"character\":89}},\"modifyRange\":{\"start\":{\"line\":10,\"character\":0},\"end\":{\"line\":10,\"character\":89}},\"action\":\"None\",\"isLine\":false,\"originText\":\"const Background3D = dynamic(() => import(\\\\'../components/Background3D\\\\'), { ssr: false });\",\"originAcceptText\":\"const Background3D = dynamic(() => import('../components/Background3D'), { ssr: false });\",\"originTextLength\":89,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767020346791},{\"originRange\":{\"start\":{\"line\":278,\"character\":0},\"end\":{\"line\":278,\"character\":24}},\"modifyRange\":{\"start\":{\"line\":278,\"character\":0},\"end\":{\"line\":278,\"character\":24}},\"action\":\"None\",\"isLine\":false,\"originText\":\"        <Background3D />\",\"originAcceptText\":\"        <Background3D />\",\"originTextLength\":24,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767020346796},{\"originRange\":{\"start\":{\"line\":319,\"character\":0},\"end\":{\"line\":319,\"character\":70}},\"modifyRange\":{\"start\":{\"line\":319,\"character\":0},\"end\":{\"line\":319,\"character\":70}},\"action\":\"None\",\"isLine\":false,\"originText\":\"          {/* Removed repetitive chips below CTAs for cleaner hero */}\",\"originAcceptText\":\"          {/* Removed repetitive chips below CTAs for cleaner hero */}\",\"originTextLength\":70,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767020346802},{\"originRange\":{\"start\":{\"line\":100,\"character\":0},\"end\":{\"line\":100,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":100,\"character\":0},\"end\":{\"line\":100,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"\",\"originAcceptText\":\"\",\"originTextLength\":0,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767022648225},{\"originRange\":{\"start\":{\"line\":190,\"character\":0},\"end\":{\"line\":190,\"character\":72}},\"modifyRange\":{\"start\":{\"line\":190,\"character\":0},\"end\":{\"line\":190,\"character\":72}},\"action\":\"None\",\"isLine\":false,\"originText\":\"  // Theme toggling removed per request; single cohesive palette is used\",\"originAcceptText\":\"  // Theme toggling removed per request; single cohesive palette is used\",\"originTextLength\":72,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767022648231},{\"originRange\":{\"start\":{\"line\":313,\"character\":0},\"end\":{\"line\":313,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":313,\"character\":0},\"end\":{\"line\":313,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"\",\"originAcceptText\":\"\",\"originTextLength\":0,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767022648236}]",
  "range-cache-file:///Users/govind/Documents/PortFolio/kcs-govindtank/lib/resumeParser.js": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":17,\"character\":1}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":17,\"character\":1}},\"action\":\"None\",\"isLine\":false,\"originText\":\"import pdf from \\\\'pdfjs-dist\\\\';\\\\n\\\\nexport async function parseResume(pdfPath) {\\\\n  const loadingTask = pdf.getDocument(pdfPath);\\\\n  const doc = await loadingTask.promise;\\\\n  let text = \\\\'\\\\';\\\\n  for (let i = 1; i <= doc.numPages; i++) {\\\\n    const page = await doc.getPage(i);\\\\n    const content = await page.getTextContent();\\\\n    text += content.items.map(item => item.str).join(\\\\' \\\\');\\\\n  }\\\\n  // Simple parsing logic - improve as needed\\\\n  const sections = {\\\\n    experience: text.match(/Experience([\\\\\\\\s\\\\\\\\S]*?)Education/)?.[1] || \\\\'\\\\',\\\\n    education: text.match(/Education([\\\\\\\\s\\\\\\\\S]*?)Software/)?.[1] || \\\\'\\\\',\\\\n    skills: text.match(/Skills([\\\\\\\\s\\\\\\\\S]*?)Experience/)?.[1] || \\\\'\\\\',\\\\n  };\\\\n  return sections;\\\\n}\",\"originAcceptText\":\"import pdf from 'pdfjs-dist';\\n\\nexport async function parseResume(pdfPath) {\\n  const loadingTask = pdf.getDocument(pdfPath);\\n  const doc = await loadingTask.promise;\\n  let text = '';\\n  for (let i = 1; i <= doc.numPages; i++) {\\n    const page = await doc.getPage(i);\\n    const content = await page.getTextContent();\\n    text += content.items.map(item => item.str).join(' ');\\n  }\\n  // Simple parsing logic - improve as needed\\n  const sections = {\\n    experience: text.match(/Experience([\\\\s\\\\S]*?)Education/)?.[1] || '',\\n    education: text.match(/Education([\\\\s\\\\S]*?)Software/)?.[1] || '',\\n    skills: text.match(/Skills([\\\\s\\\\S]*?)Experience/)?.[1] || '',\\n  };\\n  return sections;\\n}\",\"originTextLength\":675,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767004934255},{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":92,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":92,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"import fs from \\\\'node:fs/promises\\\\';\\\\nimport path from \\\\'node:path\\\\';\\\\n\\\\nfunction extractBetween(fullText, startMarker, endMarker) {\\\\n  const startIndex = fullText.indexOf(startMarker);\\\\n  if (startIndex === -1) return \\\\'\\\\';\\\\n  const afterStart = fullText.slice(startIndex + startMarker.length);\\\\n  const endIndex = endMarker ? afterStart.indexOf(endMarker) : -1;\\\\n  return (endIndex === -1 ? afterStart : afterStart.slice(0, endIndex)).trim();\\\\n}\\\\n\\\\nfunction normalizeTokens(tokens) {\\\\n  const seen = new Set();\\\\n  const result = [];\\\\n  for (const token of tokens) {\\\\n    const cleaned = token.replace(/\\\\\\\\s+/g, \\\\' \\\\').trim();\\\\n    if (!cleaned) continue;\\\\n    const key = cleaned.toLowerCase();\\\\n    if (seen.has(key)) continue;\\\\n    seen.add(key);\\\\n    result.push(cleaned);\\\\n  }\\\\n  return result;\\\\n}\\\\n\\\\nexport function parseResumeText(fullText) {\\\\n  const professionalSummary = extractBetween(fullText, \\\\'Professional Summary\\\\', \\\\'Skills\\\\');\\\\n  const skillsBlock = extractBetween(fullText, \\\\'Skills\\\\', \\\\'Experience\\\\');\\\\n  const experienceBlock = extractBetween(fullText, \\\\'Experience\\\\', \\\\'Education\\\\');\\\\n  const educationBlock = extractBetween(fullText, \\\\'Education\\\\', \\\\'Software & Technology\\\\');\\\\n\\\\n  const rawSkillTokens = skillsBlock\\\\n    .split(/\\\\\\\\n|,/g)\\\\n    .map((s) => s.trim())\\\\n    .filter((s) => s && !/^ㅡ$/.test(s));\\\\n\\\\n  const skills = normalizeTokens(\\\\n    rawSkillTokens\\\\n      .filter((s) => !/^(Frameworks & Languages|Architectural Patterns|APIs & Networking|Application Testing|Dependency Injection|Firebase Services|Payment Integration|Reactive Programming|Deep Linking|Agile Development|DevOps Practices|State Management)$/i.test(s))\\\\n      .flatMap((s) => s.split(/\\\\\\\\s{2,}/g))\\\\n  ).slice(0, 24);\\\\n\\\\n  const experiences = [];\\\\n  const projects = [];\\\\n\\\\n  const lines = experienceBlock.split(\\\\'\\\\\\\\n\\\\').map((l) => l.trimEnd());\\\\n  let i = 0;\\\\n  while (i < lines.length) {\\\\n    const line = (lines[i] || \\\\'\\\\').trim();\\\\n    const next = (lines[i + 1] || \\\\'\\\\').trim();\\\\n\\\\n    const isJobHeader = line.includes(\\\\' / \\\\') && next.match(/\\\\\\\\b\\\\\\\\d{4}\\\\\\\\b|\\\\\\\\bPRESENT\\\\\\\\b|\\\\\\\\bAPRIL\\\\\\\\b|\\\\\\\\bMARCH\\\\\\\\b|\\\\\\\\bAUG\\\\\\\\b|\\\\\\\\bDEC\\\\\\\\b/i);\\\\n    if (!isJobHeader) {\\\\n      i += 1;\\\\n      continue;\\\\n    }\\\\n\\\\n    const [company, role] = line.split(\\\\' / \\\\').map((s) => s.trim());\\\\n    const periodLine = next;\\\\n    i += 2;\\\\n\\\\n    const highlights = [];\\\\n    while (i < lines.length) {\\\\n      const current = (lines[i] || \\\\'\\\\').trim();\\\\n      const peek = (lines[i + 1] || \\\\'\\\\').trim();\\\\n      if (current.includes(\\\\' / \\\\') && peek.match(/\\\\\\\\b\\\\\\\\d{4}\\\\\\\\b|\\\\\\\\bPRESENT\\\\\\\\b/i)) break;\\\\n      if (/^Project Name\\\\\\\\s*:?\\\\\\\\s*$/i.test(current)) {\\\\n        i += 1;\\\\n        while (i < lines.length && (lines[i] || \\\\'\\\\').trim()) {\\\\n          const projLine = (lines[i] || \\\\'\\\\').trim();\\\\n          const name = projLine.replace(/^\\\\\\\\d+\\\\\\\\.\\\\\\\\s*/, \\\\'\\\\').trim();\\\\n          if (name) projects.push(name);\\\\n          i += 1;\\\\n        }\\\\n        continue;\\\\n      }\\\\n      const cleaned = current.replace(/^●\\\\\\\\s*/, \\\\'\\\\').trim();\\\\n      if (cleaned) highlights.push(cleaned);\\\\n      i += 1;\\\\n    }\\\\n\\\\n    experiences.push({\\\\n      company,\\\\n      role,\\\\n      period: periodLine,\\\\n      highlights,\\\\n    });\\\\n  }\\\\n\\\\n  return {\\\\n    professionalSummary,\\\\n    skills,\\\\n    experiences,\\\\n    educationText: educationBlock,\\\\n    projects: normalizeTokens(projects),\\\\n    certifications: [],\\\\n    achievementsAndAwards: [],\\\\n  };\\\\n}\\\\n\\\\nexport async function loadResumeData() {\\\\n  const resumePath = path.join(process.cwd(), \\\\'resume.txt\\\\');\\\\n  const fullText = await fs.readFile(resumePath, \\\\'utf8\\\\');\\\\n  return parseResumeText(fullText);\\\\n}\\\\n\",\"originAcceptText\":\"import fs from 'node:fs/promises';\\nimport path from 'node:path';\\n\\nfunction extractBetween(fullText, startMarker, endMarker) {\\n  const startIndex = fullText.indexOf(startMarker);\\n  if (startIndex === -1) return '';\\n  const afterStart = fullText.slice(startIndex + startMarker.length);\\n  const endIndex = endMarker ? afterStart.indexOf(endMarker) : -1;\\n  return (endIndex === -1 ? afterStart : afterStart.slice(0, endIndex)).trim();\\n}\\n\\nfunction normalizeTokens(tokens) {\\n  const seen = new Set();\\n  const result = [];\\n  for (const token of tokens) {\\n    const cleaned = token.replace(/\\\\s+/g, ' ').trim();\\n    if (!cleaned) continue;\\n    const key = cleaned.toLowerCase();\\n    if (seen.has(key)) continue;\\n    seen.add(key);\\n    result.push(cleaned);\\n  }\\n  return result;\\n}\\n\\nexport function parseResumeText(fullText) {\\n  const professionalSummary = extractBetween(fullText, 'Professional Summary', 'Skills');\\n  const skillsBlock = extractBetween(fullText, 'Skills', 'Experience');\\n  const experienceBlock = extractBetween(fullText, 'Experience', 'Education');\\n  const educationBlock = extractBetween(fullText, 'Education', 'Software & Technology');\\n\\n  const rawSkillTokens = skillsBlock\\n    .split(/\\\\n|,/g)\\n    .map((s) => s.trim())\\n    .filter((s) => s && !/^ㅡ$/.test(s));\\n\\n  const skills = normalizeTokens(\\n    rawSkillTokens\\n      .filter((s) => !/^(Frameworks & Languages|Architectural Patterns|APIs & Networking|Application Testing|Dependency Injection|Firebase Services|Payment Integration|Reactive Programming|Deep Linking|Agile Development|DevOps Practices|State Management)$/i.test(s))\\n      .flatMap((s) => s.split(/\\\\s{2,}/g))\\n  ).slice(0, 24);\\n\\n  const experiences = [];\\n  const projects = [];\\n\\n  const lines = experienceBlock.split('\\\\n').map((l) => l.trimEnd());\\n  let i = 0;\\n  while (i < lines.length) {\\n    const line = (lines[i] || '').trim();\\n    const next = (lines[i + 1] || '').trim();\\n\\n    const isJobHeader = line.includes(' / ') && next.match(/\\\\b\\\\d{4}\\\\b|\\\\bPRESENT\\\\b|\\\\bAPRIL\\\\b|\\\\bMARCH\\\\b|\\\\bAUG\\\\b|\\\\bDEC\\\\b/i);\\n    if (!isJobHeader) {\\n      i += 1;\\n      continue;\\n    }\\n\\n    const [company, role] = line.split(' / ').map((s) => s.trim());\\n    const periodLine = next;\\n    i += 2;\\n\\n    const highlights = [];\\n    while (i < lines.length) {\\n      const current = (lines[i] || '').trim();\\n      const peek = (lines[i + 1] || '').trim();\\n      if (current.includes(' / ') && peek.match(/\\\\b\\\\d{4}\\\\b|\\\\bPRESENT\\\\b/i)) break;\\n      if (/^Project Name\\\\s*:?\\\\s*$/i.test(current)) {\\n        i += 1;\\n        while (i < lines.length && (lines[i] || '').trim()) {\\n          const projLine = (lines[i] || '').trim();\\n          const name = projLine.replace(/^\\\\d+\\\\.\\\\s*/, '').trim();\\n          if (name) projects.push(name);\\n          i += 1;\\n        }\\n        continue;\\n      }\\n      const cleaned = current.replace(/^●\\\\s*/, '').trim();\\n      if (cleaned) highlights.push(cleaned);\\n      i += 1;\\n    }\\n\\n    experiences.push({\\n      company,\\n      role,\\n      period: periodLine,\\n      highlights,\\n    });\\n  }\\n\\n  return {\\n    professionalSummary,\\n    skills,\\n    experiences,\\n    educationText: educationBlock,\\n    projects: normalizeTokens(projects),\\n    certifications: [],\\n    achi