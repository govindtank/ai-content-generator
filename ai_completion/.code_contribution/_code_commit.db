  "range-cache-file:///Users/govind/Documents/PortFolio/kcs-govindtank/components/Background3D.js": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":119,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":119,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"import { useEffect, useRef } from \\\\'react\\\\';\\\\n\\\\nexport default function Background3D() {\\\\n  const containerRef = useRef(null);\\\\n  const cleanupRef = useRef(null);\\\\n\\\\n  useEffect(() => {\\\\n    let disposed = false;\\\\n    const prefersReduced = typeof window !== \\\\'undefined\\\\' &&\\\\n      window.matchMedia &&\\\\n      window.matchMedia(\\\\'(prefers-reduced-motion: reduce)\\\\').matches;\\\\n    const isMobile = typeof window !== \\\\'undefined\\\\' && window.innerWidth < 640;\\\\n    if (prefersReduced || isMobile) return;\\\\n    let scene, camera, renderer, group, particles, animId = 0, lastX = 0, lastY = 0, width = 0, height = 0;\\\\n    async function run() {\\\\n      const THREE = await import(\\\\'three\\\\');\\\\n      if (disposed) return;\\\\n      width = containerRef.current.clientWidth;\\\\n      height = containerRef.current.clientHeight;\\\\n      scene = new THREE.Scene();\\\\n      camera = new THREE.PerspectiveCamera(55, width / height, 0.1, 1000);\\\\n      camera.position.z = 42;\\\\n      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\\\\n      renderer.setSize(width, height);\\\\n      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));\\\\n      renderer.domElement.setAttribute(\\\\'aria-hidden\\\\', \\\\'true\\\\');\\\\n      containerRef.current.appendChild(renderer.domElement);\\\\n\\\\n      const light = new THREE.DirectionalLight(0xffffff, 0.6);\\\\n      light.position.set(0, 20, 20);\\\\n      scene.add(light);\\\\n      const ambient = new THREE.AmbientLight(0xffffff, 0.4);\\\\n      scene.add(ambient);\\\\n\\\\n      group = new THREE.Group();\\\\n      scene.add(group);\\\\n      const colors = [0xf97316, 0xfb923c, 0xf59e0b];\\\\n      const geoms = [\\\\n        new THREE.BoxGeometry(2.2, 2.2, 2.2),\\\\n        new THREE.SphereGeometry(1.8, 24, 24),\\\\n        new THREE.ConeGeometry(1.6, 2.4, 16),\\\\n      ];\\\\n      for (let i = 0; i < 18; i += 1) {\\\\n        const mat = new THREE.MeshStandardMaterial({\\\\n          color: colors[i % colors.length],\\\\n          roughness: 0.6,\\\\n          metalness: 0.2,\\\\n          transparent: true,\\\\n          opacity: 0.85,\\\\n        });\\\\n        const mesh = new THREE.Mesh(geoms[i % geoms.length], mat);\\\\n        mesh.position.set(\\\\n          (Math.random() - 0.5) * 40,\\\\n          (Math.random() - 0.5) * 30,\\\\n          (Math.random() - 0.5) * 30\\\\n        );\\\\n        mesh.rotation.set(\\\\n          Math.random() * Math.PI,\\\\n          Math.random() * Math.PI,\\\\n          Math.random() * Math.PI\\\\n        );\\\\n        mesh.userData.v = 0.002 + Math.random() * 0.004;\\\\n        group.add(mesh);\\\\n      }\\\\n\\\\n      // Particles\\\\n      const particleCount = 240;\\\\n      const positions = new Float32Array(particleCount * 3);\\\\n      for (let i = 0; i < particleCount; i++) {\\\\n        positions[i * 3] = (Math.random() - 0.5) * 60;\\\\n        positions[i * 3 + 1] = (Math.random() - 0.5) * 40;\\\\n        positions[i * 3 + 2] = (Math.random() - 0.5) * 40;\\\\n      }\\\\n      const pGeom = new THREE.BufferGeometry();\\\\n      pGeom.setAttribute(\\\\'position\\\\', new THREE.BufferAttribute(positions, 3));\\\\n      const pMat = new THREE.PointsMaterial({ color: 0xffffff, size: 0.06, opacity: 0.6, transparent: true });\\\\n      particles = new THREE.Points(pGeom, pMat);\\\\n      scene.add(particles);\\\\n\\\\n      const onMouseMove = (e) => {\\\\n        const rect = containerRef.current.getBoundingClientRect();\\\\n        const x = ((e.clientX - rect.left) / rect.width) * 2 - 1;\\\\n        const y = -(((e.clientY - rect.top) / rect.height) * 2 - 1);\\\\n        lastX = x;\\\\n        lastY = y;\\\\n      };\\\\n      window.addEventListener(\\\\'mousemove\\\\', onMouseMove, { passive: true });\\\\n\\\\n      const onResize = () => {\\\\n        width = containerRef.current.clientWidth;\\\\n        height = containerRef.current.clientHeight;\\\\n        renderer.setSize(width, height);\\\\n        camera.aspect = width / height;\\\\n        camera.updateProjectionMatrix();\\\\n      };\\\\n      window.addEventListener(\\\\'resize\\\\', onResize);\\\\n\\\\n      const loop = () => {\\\\n        animId = requestAnimationFrame(loop);\\\\n        camera.position.x += (lastX * 2 - camera.position.x) * 0.02;\\\\n        camera.position.y += (lastY * 2 - camera.position.y) * 0.02;\\\\n        camera.lookAt(scene.position);\\\\n        group.children.forEach((m, i) => {\\\\n          m.rotation.x += m.userData.v;\\\\n          m.rotation.y += m.userData.v;\\\\n          m.position.y += Math.sin(Date.now() * 0.001 + i) * 0.003;\\\\n        });\\\\n        renderer.render(scene, camera);\\\\n      };\\\\n      loop();\\\\n\\\\n      cleanupRef.current = () => {\\\\n        cancelAnimationFrame(animId);\\\\n        window.removeEventListener(\\\\'mousemove\\\\', onMouseMove);\\\\n        window.removeEventListener(\\\\'resize\\\\', onResize);\\\\n        renderer.dispose();\\\\n        geoms.forEach((g) => g.dispose());\\\\n        pGeom.dispose();\\\\n      };\\\\n    }\\\\n    run();\\\\n    return () => {\\\\n      disposed = true;\\\\n      if (cleanupRef.current) cleanupRef.current();\\\\n    };\\\\n  }, []);\\\\n\\\\n  return <div className=\\\\\\\"bg-3d\\\\\\\" ref={containerRef} aria-hidden=\\\\\\\"true\\\\\\\" />;\\\\n}\\\\n\",\"originAcceptText\":\"import { useEffect, useRef } from 'react';\\n\\nexport default function Background3D() {\\n  const containerRef = useRef(null);\\n  const cleanupRef = useRef(null);\\n\\n  useEffect(() => {\\n    let disposed = false;\\n    const prefersReduced = typeof window !== 'undefined' &&\\n      window.matchMedia &&\\n      window.matchMedia('(prefers-reduced-motion: reduce)').matches;\\n    const isMobile = typeof window !== 'undefined' && window.innerWidth < 640;\\n    if (prefersReduced || isMobile) return;\\n    let scene, camera, renderer, group, particles, animId = 0, lastX = 0, lastY = 0, width = 0, height = 0;\\n    async function run() {\\n      const THREE = await import('three');\\n      if (disposed) return;\\n      width = containerRef.current.clientWidth;\\n      height = containerRef.current.clientHeight;\\n      scene = new THREE.Scene();\\n      camera = new THREE.PerspectiveCamera(55, width / height, 0.1, 1000);\\n      camera.position.z = 42;\\n      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });\\n      renderer.setSize(width, height);\\n      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.5));\\n      renderer.domElement.setAttribute('aria-hidden', 'true');\\n      containerRef.current.appendChild(renderer.domElement);\\n\\n      const light = new THREE.DirectionalLight(0xffffff, 0.6);\\n      light.position.set(0, 20, 20);\\n      scene.add(light);\\n      const ambient = new THREE.AmbientLight(0xffffff, 0.4);\\n      scene.add(ambient);\\n\\n      group = new THREE.Group();\\n      scene.add(group);\\n      const colors = [0xf97316, 0xfb923c, 0xf59e0b];\\n      const geoms = [\\n        new THREE.BoxGeometry(2.2, 2.2, 2.2),\\n        new THREE.SphereGeometry(1.8, 24, 24),\\n        new THREE.ConeGeometry(1.6, 2.4, 16),\\n      ];\\n      for (let i = 0; i < 18; i += 1) {\\n        const mat = new THREE.MeshStandardMaterial({\\n          color: colors[i % colors.length],\\n          roughness: 0.6,\\n          metalness: 0.2,\\n          transparent: true,\\n          opacity: 0.85,\\n        });\\n        const mesh = new THREE.Mesh(geoms[i % geoms.length], mat);\\n        mesh.position.set(\\n          (Math.random() - 0.5) * 40,\\n          (Math.random() - 0.5) * 30,\\n          (Math.random() - 0.5) * 30\\n        );\\n        mesh.rotation.set(\\n          Math.random() * Math.PI,\\n          Math.random() * Math.PI,\\n          Math.random() * Math.PI\\n        );\\n        mesh.userData.v = 0.002 + Math.random() * 0.004;\\n        group.add(mesh);\\n      }\\n\\n      // Particles\\n      const particleCount = 240;\\n      const positions = new Float32Array(particleCount * 3);\\n      for (let i = 0; i < particleCount; i++) {\\n        positions[i * 3] = (Math.random() - 0.5) * 60;\\n        positions[i * 3 + 1] = (Math.random() - 0.5) * 40;\\n        positions[i * 3 + 2] = (Math.random() - 0.5) * 40;\\n      }\\n      const pGeom = new THREE.BufferGeometry();\\n      pGeom.setAttribute('position', new THREE.BufferAttribute(positions, 3));\\n      const pMat = new THREE.PointsMaterial({ color: 0xffffff, size: 0.06, opacity: 0.6, transparent: true });\\n      particles = new THREE.Points(pGeom, pMat);\\n      scene.add(particles);\\n\\n      const onMouseMove = (e) => {\\n        const rect = containerRef.current.getBoundingClientRect();\\n        const x = ((e.clientX - rect.left) / rect.width) * 2 - 1;\\n        const y = -(((e.clientY - rect.top) / rect.height) * 2 - 1);\\n        lastX = x;\\n        lastY = y;\\n      };\\n      window.addEventListener('mousemove', onMouseMove, { passive: true });\\n\\n      const onResize = () => {\\n        width = containerRef.current.clientWidth;\\n        height = containerRef.current.clientHeight;\\n        renderer.setSize(width, height);\\n        camera.aspect = width / height;\\n        camera.updateProjectionMatrix();\\n      };\\n      window.addEventListener('resize', onResize);\\n\\n      const loop = () => {\\n        animId = requestAnimationFrame(loop);\\n        camera.position.x += (lastX * 2 - camera.position.x) * 0.02;\\n        camera.position.y += (lastY * 2 - camera.position.y) * 0.02;\\n        camera.lookAt(scene.position);\\n        group.children.forEach((m, i) => {\\n          m.rotation.x += m.userData.v;\\n          m.rotation.y += m.userData.v;\\n          m.position.y += Math.sin(Date.now() * 0.001 + i) * 0.003;\\n        });\\n        renderer.render(scene, camera);\\n      };\\n      loop();\\n\\n      cleanupRef.current = () => {\\n        cancelAnimationFrame(animId);\\n        window.removeEventListener('mousemove', onMouseMove);\\n        window.removeEventListener('resize', onResize);\\n        renderer.dispose();\\n        geoms.forEach((g) => g.dispose());\\n        pGeom.dispose();\\n      };\\n    }\\n    run();\\n    return () => {\\n      disposed = true;\\n      if (cleanupRef.current) cleanupRef.current();\\n    };\\n  }, []);\\n\\n  return <div className=\\\"bg-3d\\\" ref={containerRef} aria-hidden=\\\"true\\\" />;\\n}\\n\",\"originTextLength\":4791,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767020346783},{\"originRange\":{\"start\":{\"line\":21,\"character\":0},\"end\":{\"line\":21,\"character\":29}},\"modifyRange\":{\"start\":{\"line\":21,\"character\":0},\"end\":{\"line\":21,\"character\":29}},\"action\":\"None\",\"isLine\":false,\"originText\":\"      camera.position.z = 46;\",\"originAcceptText\":\"      camera.position.z = 46;\",\"originTextLength\":29,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1767022172207},{\"originRange\":{\"start\":{\"line\":36,\"character\":0},\"end\":{\"line\":94,\"character\":25}},\"modifyRange\":{\"start\":{\"line\":36,\"character\":0},\"end\":{\"line\":94,\"character\":25}},\"action\":\"None\",\"isLine\":false,\"originText\":\"      const texLoader = new THREE.TextureLoader();\\\\n      const makeLogoBox = (texturePath, size = 8, depth = 0.6) => {\\\\n        const tex = texLoader.load(texturePath);\\\\n        tex.colorSpace = THREE.SRGBColorSpace;\\\\n        const geom = new THREE.BoxGeometry(size, size, depth);\\\\n        const materials = [\\\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // left\\\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // right\\\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // top\\\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // bottom\\\\n          new THREE.MeshStandardMaterial({ map: tex, transparent: true, roughness: 0.6, metalness: 0.2 }), // front\\\\n          new THREE.MeshStandardMaterial({ color: 0x121212, metalness: 0.2, roughness: 0.7 }), // back\\\\n        ];\\\\n        const mesh = new THREE.Mesh(geom, materials);\\\\n        mesh.castShadow = false;\\\\n        mesh.receiveShadow = false;\\\\n        mesh.userData.v = 0.003 + Math.random() * 0.003;\\\\n        return mesh;\\\\n      };\\\\n\\\\n      // Flutter and Java logos from images, Kotlin and Node rendered programmatically\\\\n      const flutterBox = makeLogoBox(\\\\'/images/projects/flutter.png\\\\', 8);\\\\n      flutterBox.position.set(-16, 6, -6);\\\\n      group.add(flutterBox);\\\\n\\\\n      const javaBox = makeLogoBox(\\\\'/images/projects/java.png\\\\', 9);\\\\n      javaBox.position.set(12, -4, -2);\\\\n      group.add(javaBox);\\\\n\\\\n      // Kotlin: two colored planes forming the \\\\'K\\\\' diagonal style\\\\n      const kotGeom1 = new THREE.PlaneGeometry(8, 8);\\\\n      const kotMat1 = new THREE.MeshStandardMaterial({ color: 0xff6f00, side: THREE.DoubleSide, metalness: 0.2, roughness: 0.6 });\\\\n      const kot1 = new THREE.Mesh(kotGeom1, kotMat1);\\\\n      kot1.position.set(-2, -10, -4);\\\\n      kot1.rotation.set(0, Math.PI / 16, 0);\\\\n      const kotGeom2 = new THREE.PlaneGeometry(8, 8);\\\\n      const kotMat2 = new THREE.MeshStandardMaterial({ color: 0x8b5cf6, side: THREE.DoubleSide, metalness: 0.2, roughness: 0.6 });\\\\n      const kot2 = new THREE.Mesh(kotGeom2, kotMat2);\\\\n      kot2.position.set(-2.5, -10.5, -5);\\\\n      kot2.rotation.set(0, -Math.PI / 18, 0);\\\\n      group.add(kot1);\\\\n      group.add(kot2);\\\\n      kot1.userData.v = 0.0035;\\\\n      kot2.userData.v = 0.0032;\\\\n\\\\n      // Node.js hexagon\\\\n      const hexShape = new THREE.Shape();\\\\n      const R = 4.2;\\\\n      for (let i = 0; i < 6; i++) {\\\\n        const angle = (Math.PI / 3) * i;\\\\n        const x = Math.cos(angle) * R;\\\\n        const y = Math.sin(angle) * R;\\\\n        if (i === 0) hexShape.moveTo(x, y);\\\\n        else hexShape.lineTo(x, y);\\\\n      }\\\\n      hexShape.closePath();\\\\n      const hexGeom = new THREE.ShapeGeometry(hexShape);\\\\n      const hexMat = new THREE.MeshStandardMaterial({ color: 0x3fa037, metalness: 0.2, roughness: 0.6 });\\\\n      const hexMesh = new THREE.Mesh(hexGeom, hexMat);\\\\n      hexMesh.position.set(20, 8, -6);\\\\n      hexMesh.rotation.set(0, Math.PI / 24, 0);\\\\n      hexMesh.userData.v = 0.003;\\\\n      group.add(hexMesh);\",\"originAcceptText\":\"      const texLoader = new THREE.TextureLoader();\\n      const makeLogoBox = (texturePath, size = 8, depth = 0.6) => {\\n        const tex = texLoader.load(texturePath);\\n        tex.colorSpace = THREE.SRGBColorSpace;\\n        const geom = new THREE.BoxGeometry(size, size, depth);\\n        const materials = [\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // left\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // right\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // top\\n          new THREE.MeshStandardMaterial({ color: 0x0f0f0f, metalness: 0.3, roughness: 0.6 }), // bottom\\n          new THREE.MeshStandardMaterial({ map: tex, transparent: true, roughness: 0.6, metalness: 0.2 }), // front\\n          new THREE.MeshStandardMaterial({ color: 0x121212, metalness: 0.2, roughness: 0.7 }), // back\\n        ];\\n        const mesh = new THREE.Mesh(geom, materials);\\n        mesh.castShadow = false;\\n        mesh.receiveShadow = false;\\n        mesh.userData.v = 0.003 + Math.random() * 0.003;\\n        return mesh;\\n      };\\n\\n      // Flutter and Java logos from images, Kotlin and Node rendered programmatically\\n      const flutterBox = makeLogoBox('/images/projects/flutter.png', 8);\\n      flutterBox.position.set(-16, 6, -6);\\n      group.add(flutterBox);\\n\\n      const javaBox = makeLogoBox('/images/projects/java.png', 9);\\n      javaBox.position.set(12, -4, -2);\\n      group.add(javaBox);\\n\\n      // Kotlin: two colored planes forming the 'K' diagonal style\\n      const kotGeom1 = new THREE.PlaneGeometry(8, 8);\\n      const kotMat1 = new THREE.MeshStandardMaterial({ color: 0xff6f00, side: THREE.DoubleSide, metalness: 0.2, roughness: 0.6 });\\n      const kot1 = new THREE.Mesh(kotGeom1, kotMat1);\\n      kot1.position.set(-2, -10, -4);\\n      kot1.rotation.set(0, Math.PI / 16, 0);\\n      const kotGeom2 = new THREE.PlaneGeometry(8, 8);\\n      const kotMat2 = new THREE.MeshStandardMaterial({ color: 0x8b5cf6, side: THREE.DoubleSide, metalness: 0.2, roughness: 0.6 });\\n      const kot2 = new THREE.Mesh(kotGeom2, kotMat2);\\n      kot2.position.set(-2.5, -10.5, -5);\\n      kot2.rotation.set(0, -Math.PI / 18, 0);\\n      group.add(kot1);\\n      group.add(kot2);\\n      kot1.userData.v = 0.0035;\\n      kot2.userData.v = 0.0032;\\n\\n      // Node.js hexagon\\n      const hexShape = new THREE.Shape();\\n      const R = 4.2;\\n      for (let i = 0; i < 6; i++) {\\n        const angle = (Math.PI / 3) * i;\\n        const x = Math.cos(angle) * R;\\n        const y = Math.sin(angle) * R;\\n        if (i === 0) hexShape.moveTo(x, y);\\n        else hexShape.lineTo(x, y);\\n      }\\n      hexShape.closePath();\\n      const hexGeom = new THREE.ShapeGeometry(hexShape);\\n      const hexMat = new THREE.MeshStandardMaterial({ color: 0x3fa037,