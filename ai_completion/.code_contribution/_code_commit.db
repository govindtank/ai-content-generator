          <select id=\\\\\\\"skills-sort\\\\\\\" value={sortBy} onChange={(e) => setSortBy(e.target.value)}>\\\\n            <option value=\\\\\\\"desc\\\\\\\">High to Low</option>\\\\n            <option value=\\\\\\\"asc\\\\\\\">Low to High</option>\\\\n          </select>\\\\n        </div>\\\\n      </div>\\\\n      <div className=\\\\\\\"skills-bars\\\\\\\">\\\\n        {sorted.map((e) => (\\\\n          <div key={e.name} className=\\\\\\\"skill-row\\\\\\\" aria-label={`${e.name} rating ${e.score}%`}>\\\\n            <div className=\\\\\\\"skill-label\\\\\\\">{e.name}</div>\\\\n            <div className=\\\\\\\"skill-bar\\\\\\\">\\\\n              <div className=\\\\\\\"skill-fill\\\\\\\" style={{ width: `${e.score}%` }}>\\\\n                <span className=\\\\\\\"skill-score\\\\\\\">{e.score}%</span>\\\\n              </div>\\\\n            </div>\\\\n          </div>\\\\n        ))}\\\\n      </div>\\\\n    </div>\\\\n  );\",\"originAcceptText\":\"export default function SkillsChart({ skills = [] }) {\\n  const initial = useMemo(\\n    () =>\\n      skills.map((s) => ({\\n        name: s,\\n        score: baseScore(s),\\n      })),\\n    [skills]\\n  );\\n  const [entries, setEntries] = useState(initial);\\n  const [sortBy, setSortBy] = useState('desc');\\n\\n  const sorted = useMemo(() => {\\n    const list = [...entries];\\n    list.sort((a, b) => (sortBy === 'asc' ? a.score - b.score : b.score - a.score));\\n    return list;\\n  }, [entries, sortBy]);\\n\\n  const shuffle = () => {\\n    setEntries((prev) =>\\n      prev.map((e) => ({\\n        ...e,\\n        score: Math.max(20, Math.min(100, Math.round(e.score * (0.7 + Math.random() * 0.6)))),\\n      }))\\n    );\\n  };\\n\\n  return (\\n    <div>\\n      <div className=\\\"skills-toolbar\\\">\\n        <button onClick={shuffle}>Shuffle Ratings</button>\\n        <div className=\\\"skills-sort\\\">\\n          <label htmlFor=\\\"skills-sort\\\">Sort</label>\\n          <select id=\\\"skills-sort\\\" v