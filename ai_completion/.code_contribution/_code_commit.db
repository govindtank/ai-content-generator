bottom) / 2) * 0.0006;\\\\n              obj.vel.x += dx;\\\\n              obj.vel.y += dy;\\\\n              closeToText = true;\\\\n            }\\\\n          }\\\\n          // Bounds wrapping\\\\n          if (mesh.position.x < -30) mesh.position.x = 30;\\\\n          if (mesh.position.x > 30) mesh.position.x = -30;\\\\n          if (mesh.position.y < -20) mesh.position.y = 20;\\\\n          if (mesh.position.y > 20) mesh.position.y = -20;\\\\n\\\\n          // Glow adjustment near text\\\\n          if (obj.glow) {\\\\n            obj.glow.position.copy(mesh.position.clone());\\\\n            obj.glow.material.opacity += ((closeToText ? 0.35 : 0.0) - obj.glow.material.opacity) * 0.08;\\\\n          }\",\"originAcceptText\":\"        });\\n\\n        // Collision avoidance with foreground text areas\\n        const rects = [];\\n        document.querySelectorAll('.hero-content, .card, .section-title').forEach((el) => {\\n          const r = el.getBoundingClientRect();\\n          rects.push(r);\\n        });\\n\\n        moving.forEach((obj) => {\\n          const mesh = obj.mesh;\\n          mesh.position.add(obj.vel);\\n          // screen projection\\n          const v = mesh.position.clone().project(camera);\\n          const sx = (v.x * 0.5 + 0.5) * width;\\n          const sy = (v.y * -0.5 + 0.5) * height;\\n          let closeToText = false;\\n          for (const r of rects) {\\n            if (sx >= r.left && sx <= r.right && sy >= r.top && sy <= r.bottom) {\\n              // Apply gentle repulsion\\n              const dx = (sx - (r.left + r.right) / 2) * 0.0006;\\n              const dy = (sy - (r.top + r.bottom) / 2) * 0.0006;\\n              obj.vel.x += dx;\\n              obj.vel.y += dy;\\n              closeToText = true;\\n            }\\n          }\\n          // Bounds wrapping\\n          if (mesh.position.x < -30) mesh.position.x = 30;\\n          if (mesh.position.x > 30) mesh.position.x = -30;\\n          if (mesh.position.y < -20) me